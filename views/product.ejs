<main>
  <section class="product-details">
    <h1>
      <%= product.namn %>
    </h1>
    <img src="<%= product.image_url  %>" alt="<%= product.namn %>">
    <div class="t-shirt"><%= product.namn %></div>
      <div class="levis"><%= product.brand %></div>
      <p class="beskrivning">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Tincidunt, justo erat facilisis urna, nec ultricies justo nulla non urna.<%= product.description %></p>
    <p class="price">
      <%= product.price %>
    </p>
    
    <button>Add to Cart</button>
  </section>
</main>