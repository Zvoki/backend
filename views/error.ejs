<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <title>error</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem; }
    h1 { color: #b30000; }
    pre { background: #f4f4f4; padding: 1rem; }
  </style>
</head>
<body>
  <h1><%= message %></h1>
  <% if (error.status) { %>
    <p>Status: <%= error.status %></p>
  <% } %>
  <% if (error.stack) { %>
    <pre><%= error.stack %></pre>
  <% } %>
</body>
</html>
